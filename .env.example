# ==========================================================================
#  hyperliquid-agent-jarvis — example environment
#  Copy to `.env` and fill in values. Never commit `.env`.
# ==========================================================================

# ---- LLM (Gemini free tier) ----
# Get key from https://aistudio.google.com/apikey  (no credit card needed)
GEMINI_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
MAX_TOKENS=4096

# ---- Paper-trading mode (MASTER SWITCH) ----
# When true: all orders go to PaperBroker (SQLite). Real Hyperliquid order APIs are refused.
PAPER_TRADING_MODE=true
PAPER_STARTING_BALANCE=1000       # simulate $1,000 USDC
PAPER_ENTRY_SLIPPAGE_PCT=0.05     # 0.05% slippage applied on fills for realism

# ---- Hyperliquid (read-only in paper mode; leave blank unless going live) ----
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_VAULT_ADDRESS=
HYPERLIQUID_NETWORK=mainnet
HYPERLIQUID_BASE_URL=

# ---- Runtime ----
ASSETS=BTC ETH SOL
INTERVAL=1h                        # supported: Nm, Nh, Nd (e.g. 5m, 1h, 1d)

# ---- Opportunity scanner (stage-1 funnel) ----
# When true, every cycle ranks ALL Hyperliquid perps and sends top-N to Gemini
# instead of only the static ASSETS list. Open positions are always pinned.
SCAN_ENABLED=true
SCAN_TOP_N=15

# ---- US Stocks via Alpaca (paper) ----
# Generate keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
STOCK_ASSETS=SPY QQQ NVDA AAPL MSFT AMZN GOOG META TSLA AVGO

# ---- Storage / logging ----
DATABASE_PATH=./data/trades.db
LLM_LOG_DIR=./data/llm_logs
LOG_DIR=./logs
LOG_LEVEL=INFO

# ---- HTTP API for the dashboard ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Risk limits (hard-enforced, regardless of LLM output) ----
MAX_POSITION_PCT=10                # single position ≤ 10% of account
MAX_LOSS_PER_POSITION_PCT=20       # force-close at -20%
MAX_LEVERAGE=3                     # paper mode tighter than original
MAX_TOTAL_EXPOSURE_PCT=50
DAILY_LOSS_CIRCUIT_BREAKER_PCT=10
MANDATORY_SL_PCT=5                 # auto-SL if LLM omits
MAX_CONCURRENT_POSITIONS=10
MIN_BALANCE_RESERVE_PCT=20
